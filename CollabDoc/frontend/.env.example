# Frontend environment — copy to `.env.local` and edit as needed.
#
# In development the Vite proxy (vite.config.ts) forwards `/api` and `/ws`
# to http://localhost:8000 / ws://localhost:8000 automatically, so these
# variables can usually be left blank. Set them for staging / prod builds
# where the frontend and backend live on different origins.
#
# Only variables prefixed with `VITE_` are exposed to client code.

# Base URL for REST API calls. Leave blank in dev to use the Vite proxy.
# Example for a deployed build:
#   VITE_API_URL=https://api.collabdoc.example.com/api/v1
VITE_API_URL=

# Base URL for the Yjs WebSocket endpoint. The document id is appended
# as the room name by `y-websocket`. Leave blank in dev.
# Example:
#   VITE_WS_URL=wss://api.collabdoc.example.com/ws
VITE_WS_URL=
