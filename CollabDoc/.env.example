# Copy this file to backend/.env and edit as needed.
#   cp .env.example backend/.env
#
# The defaults below are enough to run the demo locally — the only value
# you really want to change for any non-throwaway deployment is
# JWT_SECRET_KEY.

# ── JWT ───────────────────────────────────────────────────
# Signing key for both access (20 min) and refresh (7 d) tokens.
JWT_SECRET_KEY=change-me-to-a-random-256-bit-secret

# ── LLM ───────────────────────────────────────────────────
# The backend ships with a deterministic MockLLMProvider (see
# app/services/ai/provider.py) so no external key is required to run
# the AI panel end-to-end. If you swap the provider for a real one
# (e.g. Gemini), add its key here and read it from settings.
# GEMINI_API_KEY=
